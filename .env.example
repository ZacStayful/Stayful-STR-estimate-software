# Stayful Intelligence — example environment file
# Copy to .env.local for development and populate the secrets.
# All the same vars must be set in Vercel (Preview + Production).

# ─── Supabase (auth + postgres) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — bypasses RLS; set only as a server-side secret.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Stripe (Pro subscription) ───────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ID for the £29/mo Pro plan (starts `price_`).
STRIPE_PRO_PRICE_ID=

# ─── App URLs ───────────────────────────────────────────────────
# Used for Stripe redirect URLs and OAuth callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Internal base for the existing Stayful analyse API (used by the legacy tool).
INTERNAL_API_BASE_URL=http://localhost:3000

# ─── Analyser API keys (used by the shared estimate pipeline) ───
# These power the Airbnb/long-let/demand-driver lookups consumed by
# /api/estimate via the lib functions in src/lib/apis/*.
AIRBTICS_API_KEY=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=
GEOCODE_API_KEY=
