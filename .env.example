# ──────────────────────────────────────────────────────────────
# Core third-party API keys (estimate engine)
# ──────────────────────────────────────────────────────────────
AIRBTICS_API_KEY=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=
PRICELABS_API_KEY=

# Dev-only: bypass rate limiting + auth on /api/analyse when this header
# (x-calibration-bypass) matches. Leave blank in production.
CALIBRATION_BYPASS_SECRET=

# ──────────────────────────────────────────────────────────────
# Monday.com CRM integration — Management Leads board
# Only MONDAY_API_TOKEN is strictly required — board/column IDs default
# to the Management Leads board in src/lib/apis/monday.ts. If the token
# is missing the sync silently no-ops.
# ──────────────────────────────────────────────────────────────
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_EMAIL_COLUMN_ID=
MONDAY_LONG_TERM_LET_COLUMN_ID=
MONDAY_DEAL_ANALYSER_COLUMN_ID=

# ──────────────────────────────────────────────────────────────
# Supabase (auth + Postgres for the SaaS shell)
# Project Settings → API.
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — bypasses RLS; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────
# Stripe (£29/mo Pro subscription)
# ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Signing secret from the webhook endpoint pointing at /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=
# Recurring price ID for the £29/mo Pro plan (starts `price_`).
STRIPE_PRO_PRICE_ID=

# ──────────────────────────────────────────────────────────────
# App URL — used for Stripe redirects + Supabase OAuth callbacks.
# Locally: http://localhost:3000
# Vercel:  https://your-production-domain
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
