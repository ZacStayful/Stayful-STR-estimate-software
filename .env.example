# ──────────────────────────────────────────────────────────────
# Core third-party API keys
# ──────────────────────────────────────────────────────────────
AIRBTICS_API_KEY=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=
PRICELABS_API_KEY=

# Dev-only: bypass rate limiting on /api/analyse when this header
# (x-calibration-bypass) matches. Leave blank in production.
CALIBRATION_BYPASS_SECRET=

# ──────────────────────────────────────────────────────────────
# Monday.com CRM integration — Management Leads board
# All five must be set for /api/analyse to push results to Monday.
# If any is missing, the sync silently no-ops.
# ──────────────────────────────────────────────────────────────
# Personal API token (Profile → Developers → API). KEEP SECRET.
MONDAY_API_TOKEN=

# "Management Leads" board id.
# Find: https://monday.com/developers/v2/try-it-yourself
#   query { boards(limit: 100) { id name } }
MONDAY_BOARD_ID=

# Column id of the email field on that board (type: email).
# Find: query { boards(ids: [BOARD_ID]) { columns { id title type } } }
MONDAY_EMAIL_COLUMN_ID=

# Column id of the "Long term let" column — receives the annual net
# of long-term rent (financials.longLetNetAnnual).
MONDAY_LONG_TERM_LET_COLUMN_ID=

# Column id of the "Stayful Deal Analyser" column — receives the
# short-term let annual net revenue (financials.shortLetNetAnnual).
MONDAY_DEAL_ANALYSER_COLUMN_ID=
