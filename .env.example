# ──────────────────────────────────────────────────────────────
# Core third-party API keys
# ──────────────────────────────────────────────────────────────
AIRBTICS_API_KEY=
PROPERTYDATA_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=
PRICELABS_API_KEY=

# Dev-only: bypass rate limiting on /api/analyse when this header
# (x-calibration-bypass) matches. Leave blank in production.
CALIBRATION_BYPASS_SECRET=

# ──────────────────────────────────────────────────────────────
# Monday.com CRM integration — Management Leads board
#
# Only MONDAY_API_TOKEN is strictly required — the board and column
# IDs have hardcoded defaults in src/lib/apis/monday.ts pointing at
# the Management Leads board. Set the four *_ID vars below ONLY if
# you need to override those defaults (e.g. pointing at a different
# board during testing).
#
# If MONDAY_API_TOKEN is missing, the sync silently no-ops.
# ──────────────────────────────────────────────────────────────
# Personal API token (Profile → Developers → API). KEEP SECRET.
MONDAY_API_TOKEN=

# Optional overrides — defaults point at Management Leads board + its columns
MONDAY_BOARD_ID=
MONDAY_EMAIL_COLUMN_ID=
MONDAY_LONG_TERM_LET_COLUMN_ID=
MONDAY_DEAL_ANALYSER_COLUMN_ID=
